<Window
    x:Class="WallpaperAnimWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WallpaperAnim">

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="0,0,1,0">
            <Grid Padding="12,40,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,24">
                    <TextBlock Text="WallpaperAnim" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <!-- Design-time placeholder only; set at runtime from version.h (APP_VERSION_STRING_W). -->
                    <TextBlock x:Name="TxtAppVersion" Text="v1.4.6" FontSize="12" Foreground="#AAAAAA"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button x:Name="BtnLibrary" Click="Tab_Click" Tag="library" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <SymbolIcon Symbol="Pictures" Foreground="White"/>
                            <TextBlock x:Name="TxtTabLibrary" Text="Kütüphane" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAdd" Click="Tab_Click" Tag="add" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <SymbolIcon Symbol="Add" Foreground="White"/>
                            <TextBlock x:Name="TxtTabAdd" Text="Duvar Kağıdı Ekle" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSettings" Click="Tab_Click" Tag="settings" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <SymbolIcon Symbol="Setting" Foreground="White"/>
                            <TextBlock x:Name="TxtTabSettings" Text="Ayarlar" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1" Padding="24">
            
            <!-- Tab 1: Kütüphane -->
            <Grid x:Name="GridLibrary" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtLibraryHeader" Grid.Row="0" Text="Kütüphane" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1">
                    <GridView x:Name="LibraryGridView" SelectionMode="None" IsItemClickEnabled="True" ItemClick="LibraryGridView_ItemClick">
                        <!-- Items are generated dynamically in MainWindow.xaml.cpp -->
                    </GridView>
                </ScrollViewer>
            </Grid>

            <!-- Tab 2: Duvar Kağıdı Ekle -->
            <Grid x:Name="GridAdd" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtAddHeader" Grid.Row="0" Text="Duvar Kağıdı Ekle" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,24"/>

                <StackPanel Grid.Row="1" Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
                    <!-- Local File Option -->
                    <Border BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="16" Background="#2D2D30">
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="TxtLocalTitle" Text="Dosya Seç" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="TxtLocalDesc" Text="Bilgisayarınızdan video (.mp4, .avi, .mkv), GIF veya HLSL gölgelendirici dosyası seçin." Foreground="#CCCCCC"/>
                            <Button x:Name="BtnBrowse" Content="Gözat" Click="BtnBrowse_Click" Background="#0078D4" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <!-- YouTube Option -->
                    <Border BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="16" Background="#2D2D30">
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="TxtYoutubeTitle" Text="YouTube'dan İndir" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <TextBox x:Name="TxtYoutubeUrl" PlaceholderText="YouTube video bağlantısını yapıştırın (ör. https://www.youtube.com/watch?...)" Background="#1E1E1E" Foreground="White"/>
                            <Button x:Name="BtnDownload" Content="İndir ve Duvar Kağıdı Yap" Click="BtnDownload_Click" Background="#0078D4" Foreground="White"/>
                            <ProgressBar x:Name="PrgDownload" Visibility="Collapsed" Minimum="0" Maximum="100" Value="0" ShowError="False" IsIndeterminate="False"/>
                            <TextBlock x:Name="TxtDownloadStatus" Visibility="Collapsed" Foreground="#AAAAAA"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Tab 3: Ayarlar -->
            <Grid x:Name="GridSettings" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtSettingsHeader" Grid.Row="0" Text="Ayarlar" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,24"/>

                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
                        <StackPanel Spacing="4">
                            <ToggleSwitch x:Name="TglBattery" Header="Pil Gücünde Oynatmayı Duraklat" Toggled="TglBattery_Toggled" Foreground="White"/>
                            <TextBlock x:Name="TxtTglBatteryDesc" Text="Cihaz pildeyken CPU/GPU tasarrufu için duvar kağıdını duraklatır." FontSize="12" Foreground="#AAAAAA"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <ToggleSwitch x:Name="TglFullscreen" Header="Tam Ekranda Oynatmayı Duraklat" Toggled="TglFullscreen_Toggled" Foreground="White"/>
                            <TextBlock x:Name="TxtTglFullscreenDesc" Text="Başka bir uygulama tam ekran olduğunda duvar kağıdını duraklatır." FontSize="12" Foreground="#AAAAAA"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <ToggleSwitch x:Name="TglStartup" Header="Windows Başlangıcında Çalıştır" Toggled="TglStartup_Toggled" Foreground="White"/>
                            <TextBlock x:Name="TxtTglStartupDesc" Text="Bilgisayar açıldığında uygulamayı otomatik başlatır." FontSize="12" Foreground="#AAAAAA"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Name="TxtFpsLabel" Text="Maks. FPS" FontWeight="SemiBold" Foreground="White"/>
                            <ComboBox x:Name="CmbFps" Width="240" SelectionChanged="CmbFps_SelectionChanged" Background="#1E1E1E" Foreground="White">
                                <ComboBoxItem Content="Maksimum (Ekran Hz) — Akıcı"/>
                                <ComboBoxItem Content="60 FPS"/>
                                <ComboBoxItem Content="30 FPS"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Name="TxtLanguageLabel" Text="Dil (Language)" FontWeight="SemiBold" Foreground="White"/>
                            <ComboBox x:Name="CmbLanguage" Width="200" SelectionChanged="CmbLanguage_SelectionChanged" Background="#1E1E1E" Foreground="White">
                                <ComboBoxItem Content="Türkçe"/>
                                <ComboBoxItem Content="English"/>
                            </ComboBox>
                        </StackPanel>

                        <Border BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="16" Background="#2D2D30" Margin="0,20,0,0">
                            <StackPanel Spacing="12">
                                <TextBlock x:Name="TxtUpdateHeader" Text="Uygulama Güncellemesi" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                                <Button x:Name="BtnUpdate" Content="Güncellemeleri Kontrol Et" Click="BtnUpdate_Click" Background="#0078D4" Foreground="White"/>
                                <ProgressBar x:Name="PrgUpdate" Visibility="Collapsed" Minimum="0" Maximum="100" Value="0"/>
                                <TextBlock x:Name="TxtUpdateStatus" Visibility="Collapsed" Foreground="#AAAAAA"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Window>
